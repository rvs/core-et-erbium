
<%my (@params)=(
{ tbl_len=>23, major_rev=>1, minor_rev=>0x9, param_lsb=>0, param_msb=>0xff, ptp=>0x400, addr=>"6_4_" },
{ tbl_len=>2, major_rev=>1, minor_rev=>1, param_lsb=>0x84, param_msb=>0xff, ptp=>0x700, addr=>"6_7_" },
{ tbl_len=>3, major_rev=>1, minor_rev=>0, param_lsb=>0x06, param_msb=>0xff, ptp=>0x900, addr=>"6_9_" },
{ tbl_len=>28, major_rev=>1, minor_rev=>1, param_lsb=>0x87, param_msb=>0xff, ptp=>0xa00, addr=>"6_10_" },
{ tbl_len=>13, major_rev=>1, minor_rev=>0, param_lsb=>0x09, param_msb=>0xff, ptp=>0xb00, addr=>"6_11_" },
{ tbl_len=>'0x0A', major_rev=>1, minor_rev=>1, param_lsb=>0x0f, param_msb=>0xff, ptp=>0x1100, addr=>"6_17_" },
); 
%>

addrmap SFDP_Reg {
  name="SFDP Parameters CSR Registers";
  alignment=4;
default hw=na;
default sw=na;
  default regwidth=32;
  reg {
    field {sw=r; desc="SFDP Signature";} signature[31:0]=0x50444653;
  } reg6_2_1;
reg {
    field {sw=r; desc="TBD SFDP Access protocol";} access_protocol[31:24]=0xFA;
    field {sw=r;hw=r; desc="Num Parameter Header TBD";} numHdr[23:16]=<%=$#params+1%>;
    field {sw=r; desc="SFDP Version Major";} major[15:8]=1;
    field {sw=r; desc="SFDP Version Minor";} minor[7:0]=0xC;
// review table 6.2.3 FA meand 8D profile 2 this will not work for qspi bondout.
} reg6_2_2;
<% for (@params) {%>
reg {
field {sw=r;desc="Tbl Len";} tbl_len[31:24]=<%=$_->{tbl_len}%>;
field {sw=r;desc="major_rev";} major_rev[23:16]=<%=$_->{major_rev}%>;
field {sw=r;desc="minor rev";} minor_rev[15:8]=<%=$_->{minor_rev}%>;
field {sw=r;desc="parameter id lsb";} id[7:0]=<%=$_->{param_lsb}%>;
}reg<%=$_->{addr}%>_1;
reg {
field {sw=r; desc="Parameter Table ID MSB";} param_id_msb[31:24]=<%=$_->{param_msb}%>;
field {sw=r; desc="Parameter Table Pointer TBD";} param_tbl_ptr[23:0]=<%=$_->{ptp}%>;
} reg<%=$_->{addr}%>_2;
<%};%>
///////////////////////////////////////////////////////////
reg {
field {sw=r; desc="Unused";} unused0[31:23]=0xff;
field {sw=r; desc="Does not support 1S-1S-4S Fast Read";} fs_1s1s1s[22:22]=0x0;
