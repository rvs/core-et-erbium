#########
# Exclude all by default – CORRECT WAY
#########
*

# Allow traversing into all directories
!*/

# Explicitly keep the directories we care about
!.gitignore
!/3p/
!/bsv/
!/doc/
!/systemC/
!/systemrdl/
!/tb/
!/verilog/

# Now bring back the file types we want
!*.v
!*.f
!*.sv
!*.bsv
!*.bh
!*.vhdl
!*.vh
!*.sva
!*.sh
!*.pl
!*.py
!*.tcl
!*.c
!*.h
!*.rdl
!*.md
!*.drawio
!*.cfg
!*.json
!*.yaml
!*.sdc
!*.spf
!*.lib
!*.scf
!*.upf

bluespec.json

# Ignore headerize private config
.headerize.config
