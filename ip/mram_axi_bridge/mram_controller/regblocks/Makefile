# Directories
PEAKRDL_DIR     := systemrdl
VERILOG_DIR     := verilog
PYTHON_DIR      := python

# Tool name
PEAKRDL_CMD     := peakrdl

# Use the local venv toolchain for deterministic plugin availability.
PEAKRDL_TOOL := venv/bin/$(PEAKRDL_CMD)
PEAKRDL_ENV  := PYTHONPATH=$(abspath .):$(PYTHONPATH)

# RDL Files
# Only top-level addrmap RDL files should generate Verilog outputs.
# Component/regfile-only RDLs (e.g. erbium_test_registers.rdl) are listed as
# EXTRA_RDL_FILES and passed as dependencies to top-level builds, but do not
# have their own Verilog target.
EXTRA_RDL_FILES := $(PEAKRDL_DIR)/erbium_test_registers.rdl
TOP_RDL         := $(PEAKRDL_DIR)/top.rdl
EXTTOP_RDL      := $(PEAKRDL_DIR)/topexternal.rdl
VERILOG_FILES   := $(TOP_RDL:$(PEAKRDL_DIR)/%.rdl=$(VERILOG_DIR)/%.v)

# The pkg.sv file generated by PeakRDL (assumes pkg.sv is generated by peakrdl-rtl)
PKG_FILE        := $(VERILOG_DIR)/mram_tregs_pkg.sv

.PHONY: all clean check_peakrdl setup_venv python
.PHONY: test_regs_merge_seed test_regs_merge_apply

all: check_peakrdl $(VERILOG_FILES)

python: check_peakrdl $(TOP_RDL) $(EXTRA_RDL_FILES)
	@mkdir -p $(PYTHON_DIR)
	$(PEAKRDL_ENV) $(PEAKRDL_TOOL) python --async $(filter-out $(TOP_RDL),$(EXTRA_RDL_FILES)) $(TOP_RDL) -o $(PYTHON_DIR) --peakrdl-cfg $(PEAKRDL_DIR)/peakrdl.toml

test_regs_merge_seed:
	python3 merge_erbium_test_registers.py seed

test_regs_merge_apply:
	python3 merge_erbium_test_registers.py apply

# Generate Verilog from RDL
$(VERILOG_DIR)/%.v: $(PEAKRDL_DIR)/%.rdl
	@mkdir -p $(VERILOG_DIR)
	$(PEAKRDL_ENV) $(PEAKRDL_TOOL) regblock $(filter-out $(EXTTOP_RDL),$(EXTRA_RDL_FILES)) $(EXTTOP_RDL) -o $(VERILOG_DIR) --cpuif axi4-lite-flat-resp1 --peakrdl-cfg $(PEAKRDL_DIR)/peakrdl.toml
	$(PEAKRDL_ENV) $(PEAKRDL_TOOL) regblock $(filter-out $(TOP_RDL),$(EXTRA_RDL_FILES)) $(TOP_RDL) -o $(VERILOG_DIR)  --cpuif passthrough --peakrdl-cfg $(PEAKRDL_DIR)/peakrdl.toml 
	$(PEAKRDL_ENV) $(PEAKRDL_TOOL) markdown $(filter-out $<,$(EXTRA_RDL_FILES)) $< -o README.md

# Check if peakrdl-rtl is available; if not, setup venv and install requirements
check_peakrdl:
	@test -x $(PEAKRDL_TOOL) || $(MAKE) setup_venv

# Setup venv and install requirements if peakrdl-rtl not found
setup_venv:
	@echo "peakrdl not found. Creating virtual environment and installing requirements..."
	python3 -m venv venv
	./venv/bin/pip install -r requirements.txt
	@echo "Virtual environment created and peakrdl installed."

clean:
	rm -rf $(VERILOG_DIR)/*.v
