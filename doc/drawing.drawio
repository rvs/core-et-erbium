  <diagram id="Kcrs-3T-u7qdIqf63X2u" name="power_sequence">
    <mxGraphModel dx="880" dy="595" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="fVrnBPkZDg3ay9OK4ea5-2" value="&lt;h1&gt;Power Sequence&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Write to register initiates the power sequence by asserting pd_req.&lt;/li&gt;&lt;li&gt;pd_ack is asserted when there are no outstanding axi/ahb transactions.&lt;/li&gt;&lt;li&gt;iso is asserted when pd_req &amp;amp; ack are high this puts the device in isolation mode. Iso remains asserted for an extra cycle after power is switched back on.&lt;/li&gt;&lt;li&gt;poweroff is asserted when pd_req and ack are high&lt;/li&gt;&lt;li&gt;rst_n follows power off with a delay of two cycles&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="520" y="10" width="320" height="240" as="geometry" />
        </mxCell>
        <mxCell id="fVrnBPkZDg3ay9OK4ea5-3" value="" style="shape=image;aspect=fixed;image=data:image/svg+xml,;" parent="1" vertex="1">
          <mxGeometry y="10" width="520" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
